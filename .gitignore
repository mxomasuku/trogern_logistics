# ============================================
# NODE & DEPENDENCIES
# ============================================
**/node_modules/
**/dist/
**/.pnp
**/.pnp.js

# Package lock files (pick your package manager - keep ONE, ignore others)
**/package-lock.json
**/yarn.lock
**/pnpm-lock.yaml
**/bun.lockb

# ============================================
# ENVIRONMENT FILES (SECRETS - NEVER COMMIT)
# ============================================
**/.env
**/.env.local
**/.env.development
**/.env.development.local
**/.env.production
**/.env.production.local
**/.env.test
**/.env.test.local

# Firebase service accounts (CRITICAL - NEVER COMMIT)
**/*firebase-adminsdk*.json
**/*service-account*.json
**/serviceAccountKey.json

# ============================================
# NEXT.JS SPECIFIC
# ============================================
.next/
out/
build/
.swc/

# Next.js static export
/admin-dashboard/out/

# Vercel
.vercel

# ============================================
# TYPESCRIPT
# ============================================
*.tsbuildinfo
next-env.d.ts

# Compiled output (for packages/domain)
packages/domain/dist/

# ============================================
# TESTING
# ============================================
**/coverage/
**/.nyc_output/
*.lcov

# Playwright
**/playwright-report/
**/playwright/.cache/

# ============================================
# LOGS
# ============================================
**/logs/
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ============================================
# IDE & EDITOR
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# ============================================
# OS JUNK
# ============================================
**/.DS_Store
**/Thumbs.db
**/.Trash
**/.Spotlight-V100
**/.Trashes

# ============================================
# CACHE & TEMP FILES
# ============================================
**/.cache/
**/.parcel-cache/
**/.turbo/
**/.eslintcache
**/.stylelintcache
*.tmp
*.temp

# ============================================
# FIREBASE & EMULATORS
# ============================================
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
ui-debug.log
pubsub-debug.log
.firebase/

# Emulator data exports (optional - you might want to keep these)
emulator-data/
firestore-export/

# ============================================
# MISC
# ============================================
# Sentry
.sentryclirc

# PWA files
**/sw.*
**/workbox-*

# Storybook
storybook-static/

# Debug
.debug/
```
