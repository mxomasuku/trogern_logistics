{
  "name": "dashboard-api",
  "version": "1.0.0",
  "description": "",
  "main": "server.ts",
  "scripts": {
    "test": "jest",
    "start": "nodemon src/server.ts",
    "build": "tsc",
    "prod": "cross-env NODE_ENV=production node dist/server.js",
    "dev": "NODE_OPTIONS='--max-http-header-size=16384' ts-node src/server.ts",
    "emulators": "firebase emulators:start --only firestore,auth,storage --import=./.emulator-data --export-on-exit",
    "serve-local-dev": "npm run start export FIRESTORE_EMULATOR_HOST='127.0.0.1:8083' && export FIREBASE_AUTH_EMULATOR_HOST='127.0.0.1:9099' && export FIREBASE_STORAGE_EMULATOR_HOST='127.0.01:9199'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/axios": "^0.9.36",
    "axios": "^1.11.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "firebase": "^12.0.0",
    "firebase-admin": "^13.4.0",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/supertest": "^6.0.3",
    "cross-env": "^10.0.0",
    "jest": "^30.0.5",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
