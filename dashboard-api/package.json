{
  "name": "dashboard-api",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "jest",
    "build": "tsc -p tsconfig.json",
    "gcp-build": "npm run build",
    "start": "node dist/server.js",
    "deploy": "bash ./scripts/deploy-api.sh",
    "dev": "NODE_OPTIONS='--max-http-header-size=16384' nodemon --watch src --ext ts,js --exec ts-node src/server.ts",
    "set-emulators": "cross-env FIRESTORE_EMULATOR_HOST=127.0.0.1:8083 FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099",
    "serve-local-dev": "npm run build && npm run set-emulators && npm run dev",
    "prod": "cross-env NODE_ENV=production node dist/server.js"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "firebase": "^12.0.0",
    "firebase-admin": "^13.4.0",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/supertest": "^6.0.3",
    "cross-env": "^10.0.0",
    "jest": "^30.0.5",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}