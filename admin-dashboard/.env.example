# Firebase Admin SDK Configuration
# Option 1: Use service account credentials directly
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# Option 2: Use GOOGLE_APPLICATION_CREDENTIALS (recommended for production)
# Set this to the path of your service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Session Configuration
SESSION_SECRET=your-random-session-secret-min-32-chars

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3001
