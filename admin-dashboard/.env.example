# Firebase Admin SDK Configuration
# Option 1: Use service account credentials directly
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# Option 2: Use GOOGLE_APPLICATION_CREDENTIALS (recommended for production)
# Set this to the path of your service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Session Configuration
SESSION_SECRET=your-random-session-secret-min-32-chars

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Firebase Client SDK Configuration (for client-side Firestore access)
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# Emulator Configuration (for local development)
# Uncomment these for local development with Firebase emulators
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
NEXT_PUBLIC_FIREBASE_FIRESTORE_EMULATOR_HOST=localhost:8080

